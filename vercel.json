{
  "functions": {
    "api/**/*.ts": {
      "memory": 256,
      "maxDuration": 15,
      "includeFiles": "class-schedule.json"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!src/|node_modules/|@vite/|@fs/|@react-refresh|__vite|.*\\.(?:png|webp|mp4|svg|jpg|jpeg|gif|ico|woff|woff2|ttf|eot|json|css|js|map)$).*)", "destination": "/index.html" }
  ]
}
