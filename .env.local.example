# Square API — server-only (never expose in VITE_ vars)
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXXX
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_MAX_SEATS=20                    # Must match "Max customers per slot" in Square Dashboard → Services
SQUARE_CLASS_TIMES=10:30,12:00,13:30,15:00   # Comma-separated Montreal-local start times; leave blank for no filtering
SQUARE_GST_TAX_ID=                    # Square catalog tax object ID for TPS/GST (5%) — find in Square Dashboard → Taxes
SQUARE_QST_TAX_ID=                    # Square catalog tax object ID for TVQ/QST (9.975%) — find in Square Dashboard → Taxes

# Email via Resend — server-only
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Studio Yopaw <noreply@studio-yopaw.com>   # Must be a verified Resend domain
LEAD_NOTIFY_EMAIL=hello@studio-yopaw.com
PAYMENT_NOTIFY_EMAIL=hello@studio-yopaw.com

# Square — safe to expose in browser (used by Web Payments SDK + booking form)
# Run `npx tsx scripts/setup-square.ts` to generate the variation IDs automatically
VITE_SQUARE_APP_ID=sq0idp-xxxxxxxxxxxxxxxxxxxx
VITE_SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXXX
VITE_SQUARE_TEAM_MEMBER_ID=TMxxxxxxxxxxxxxxxxxx
VITE_SQUARE_MAX_SEATS=20              # Must match SQUARE_MAX_SEATS above

VITE_SQUARE_YIN_VARIATION_ID=         # Regular Puppy Yoga variation ID
VITE_SQUARE_YIN_VARIATION_VERSION=    # e.g. 1234567890
VITE_SQUARE_YIN_BASE_CENTS=4600       # Must match price set in Square Dashboard → Services ($46.00 CAD)

VITE_SQUARE_GENTLE_VARIATION_ID=      # Private Event variation ID
VITE_SQUARE_GENTLE_VARIATION_VERSION=
VITE_SQUARE_GENTLE_BASE_CENTS=4600

VITE_SQUARE_CORP_VARIATION_ID=        # Corporate variation ID
VITE_SQUARE_CORP_VARIATION_VERSION=
VITE_SQUARE_CORP_BASE_CENTS=4600
