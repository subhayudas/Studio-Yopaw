# Square API — server-only (never expose in VITE_ vars)
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXXX
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Square — safe to expose in browser (used by Web Payments SDK + booking form)
# Run `npx tsx scripts/setup-square.ts` to generate the variation IDs automatically
VITE_SQUARE_APP_ID=sq0idp-xxxxxxxxxxxxxxxxxxxx
VITE_SQUARE_LOCATION_ID=LXXXXXXXXXXXXXXXXX
VITE_SQUARE_TEAM_MEMBER_ID=TMxxxxxxxxxxxxxxxxxx

VITE_SQUARE_YIN_VARIATION_ID=           # Regular Puppy Yoga variation ID
VITE_SQUARE_YIN_VARIATION_VERSION=      # e.g. 1234567890

VITE_SQUARE_GENTLE_VARIATION_ID=        # Private Event variation ID (inquiry-only)
VITE_SQUARE_GENTLE_VARIATION_VERSION=

VITE_SQUARE_CORP_VARIATION_ID=          # Corporate variation ID (inquiry-only)
VITE_SQUARE_CORP_VARIATION_VERSION=

# Email forwarding via Resend (free: 3 000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
LEAD_NOTIFY_EMAIL=hello@studio-yopaw.com
PAYMENT_NOTIFY_EMAIL=hello@studio-yopaw.com
