{
  "name": "velorah-hero",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "square:setup-taxes": "tsx --env-file=.env.local scripts/setup-square-taxes.ts",
    "square:attach-taxes": "tsx --env-file=.env.local scripts/attach-square-taxes.ts",
    "test": "node --test tests/verify-fixes.mjs && node --test tests/availability-seat-count.test.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vercel/node": "^5.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-square-web-payments-sdk": "^3.3.0",
    "square": "^44.0.1",
    "twilio": "^6.0.2",
    "vercel": "^54.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "dotenv": "^16.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "8.0.10",
    "vitest": "^4.1.8"
  }
